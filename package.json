{
  "name": "site-factory",
  "version": "1.7.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:convex": "npx convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "qa": "npm run lint && npm run typecheck",
    "qa:perf": "npx lighthouse http://localhost:3000 --only-categories=performance,accessibility,best-practices --chrome-flags='--headless' --quiet",
    "qa:visual": "playwright test",
    "qa:visual:update": "playwright test --update-snapshots",
    "qa:all": "npm run qa && npm run qa:visual",
    "playwright:install": "playwright install chromium",
    "quick-start": "bash scripts/quick-start.sh",
    "sync:tokens": "node scripts/sync-figma-tokens.mjs",
    "theme:apply": "node scripts/apply-theme.mjs",
    "scaffold:page": "node scripts/generate-page.mjs",
    "scaffold:client": "bash scripts/scaffold-client.sh",
    "scaffold:from-brief": "node scripts/scaffold-from-brief.mjs",
    "copy:apply": "node scripts/apply-copy-pack.mjs",
    "scaffold:references": "bash scripts/scaffold-references.sh",
    "refresh:preset": "node scripts/refresh-preset.mjs",
    "sync:clone": "node scripts/sync-from-template.mjs",
    "refresh:references": "bash scripts/refresh-references.sh",
    "snapshots:references": "bash scripts/capture-reference-snapshots.sh",
    "convex:prod": "bash scripts/setup-convex-prod.sh",
    "convex:seed": "bash scripts/convex-enable-seed.sh",
    "convex:init": "bash scripts/init-convex.sh",
    "convex:vercel": "bash scripts/link-convex-vercel.sh",
    "domain:custom": "bash scripts/set-custom-domain.sh",
    "domain:verify": "bash scripts/verify-domain.sh",
    "push:references": "bash scripts/push-reference-repos.sh",
    "factory:health": "bash scripts/factory-health.sh",
    "verify:live": "bash scripts/verify-live.sh",
    "verify:storefront": "bash scripts/verify-storefront.sh",
    "verify:sitemap": "node scripts/verify-sitemap-urls.mjs",
    "verify:messages": "node scripts/verify-messages-parity.mjs",
    "verify:brief": "node scripts/verify-brief.mjs",
    "verify:prod": "bash scripts/verify-prod-i18n.sh",
    "verify:backend": "bash scripts/verify-prod-backend.sh",
    "verify:stripe": "bash scripts/verify-prod-stripe.sh",
    "verify:all": "npm run verify:messages && npm run verify:sitemap && npm run verify:prod && npm run verify:backend && npm run verify:stripe",
    "stripe:setup": "bash scripts/setup-stripe.sh",
    "prod:services": "bash scripts/setup-prod-services.sh",
    "i18n:enable": "bash scripts/enable-i18n.sh",
    "deploy:references": "bash scripts/deploy-reference.sh",
    "ship:client": "bash scripts/ship-client.sh",
    "deploy:demo-studio": "bash scripts/deploy-demo-studio.sh",
    "ship:demo-studio": "cd \"$HOME/Projects/demo-studio\" && npm run ship",
    "github:ship": "cd \"$HOME/Projects/demo-studio\" && npm run github:ship",
    "vercel:setup": "bash scripts/vercel-setup.sh",
    "vercel:git": "bash scripts/connect-vercel-git.sh",
    "deploy": "bash scripts/deploy-vercel.sh",
    "deploy:prebuilt": "bash scripts/deploy-prebuilt.sh",
    "ship:when-ready": "bash scripts/ship-when-ready.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
